# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False

# Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=edcm_db
DB_USER=edcm_user
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432

# For Render.com deployment - use this instead of individual DB vars
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Allowed Hosts
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com,your-app.onrender.com

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.onrender.com

# API Configuration
API_URL=https://your-app.onrender.com/api/
FRONTEND_URL=https://your-app.onrender.com

# Security Settings (set to True in production)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Email Configuration (optional)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# AWS S3 Configuration (optional, for file storage)
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_STORAGE_BUCKET_NAME=your_bucket_name
# AWS_S3_REGION_NAME=us-east-1

# Render.com specific
# PORT=8000 (automatically set by Render)
